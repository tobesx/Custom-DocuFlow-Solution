{
  "name": "@docuflow/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.620.0",
    "@docuflow/types": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.17.0",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prisma": "^5.17.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
